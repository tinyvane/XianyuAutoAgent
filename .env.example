OPENAI_API_KEY=your_api_key_here
COOKIES_STR=your_cookies_here

# === 风控预防 ===
MIN_REQUEST_INTERVAL=2.0
MAX_REQUEST_INTERVAL=5.0
# DEVICE_ID=                      # 自动生成并持久化，无需手动配置

# === 通知系统 ===
# NOTIFICATION_TYPE=none           # webhook/bark/serverchan/none
# NOTIFICATION_WEBHOOK_URL=        # Webhook/Bark/Server酱 URL

# === 浏览器自动化 (需要 Chrome 以 --remote-debugging-port=9222 启动) ===
# COOKIE_REFRESH_ENABLED=true
# COOKIE_REFRESH_INTERVAL=1800     # 主动刷新间隔（秒），默认30分钟
# CHROME_CDP_URL=http://localhost:9222
# SLIDER_MAX_ATTEMPTS=3

# === Cookie 手动输入服务器 ===
# COOKIE_SERVER_ENABLED=true
# COOKIE_SERVER_PORT=8765
